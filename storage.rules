rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Foto de perfil: escrita apenas pelo próprio usuário autenticado,
    // leitura pública para exibição do avatar em qualquer contexto.
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Bloqueia qualquer outro caminho por padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
