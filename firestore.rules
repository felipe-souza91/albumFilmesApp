rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uidField) {
      return isAuth()
        && resource != null
        && request.auth.uid == resource.data[uidField];
    }

    function isOwnerReq(uidField) {
      return isAuth() && request.auth.uid == request.resource.data[uidField];
    }

    // ✅ PERFIL DO USUÁRIO (faltava isso)
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && request.auth.uid == uid;
      // LGPD: permite que o próprio usuário exclua seu perfil
      allow delete: if isAuth() && request.auth.uid == uid;
    }

    match /movies/{movieId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    match /user_movies/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create, update: if isOwnerReq('userId');
      // BUG FIX: delete usa isOwner (resource.data) pois request.resource não
      // existe em operações de exclusão — isOwnerReq falharia silenciosamente.
      allow delete: if isOwner('userId');
    }

    match /achievements/{achId} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    match /user_achievements/{docId} {
      allow read: if isAuth() && (
        (resource != null && request.auth.uid == resource.data.userId) ||
        (resource == null && docId.matches('^' + request.auth.uid + '_.*$'))
      );
      allow create, update: if isOwnerReq('userId');
      // BUG FIX: mesmo fix — delete usa isOwner
      allow delete: if isOwner('userId');
    }

    match /user_metrics/{docId} {
      // Permite get() de métricas ainda não criadas (ex.: shares = 0)
      allow read: if isAuth() && (
        (resource != null && request.auth.uid == resource.data.userId) ||
        (resource == null && docId.matches('^' + request.auth.uid + '_.*$'))
      );
      allow create, update: if isOwnerReq('userId');
      // BUG FIX: mesmo fix — delete usa isOwner
      allow delete: if isOwner('userId');
    }

    match /questionnaires/{version} {
      allow read: if true;
      allow write: if request.auth.token.admin == true;
    }

    match /user_answers/{uid}/versions/{version} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /user_preferences/{uid} {
      allow read, write: if isAuth() && request.auth.uid == uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}